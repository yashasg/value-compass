# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Environment
.env
.env.*
!.env.example

# Editors / OS
.DS_Store
.idea/
.vscode/
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Generated build artifacts
build/
# SwiftPM / Xcode derived data emitted by app/build.sh and app/run.sh
# (kept locally for caching; never committed). Note: distinct from `build/`
# above — `.build` (leading dot) is what SwiftPM and Xcode-from-`app/`
# create, and the literal `build/` rule does not match it.
app/.build/
**/.build/

# iOS / Xcode user-local files
# Xcode .pbxuser, .perspectivev3 user-specific files
app/*.pbxuser
app/*.perspectivev3
# Xcode xcuserdata (build settings, breakpoints, watchpoints)
app/*.xcworkspace/xcuserdata/
app/*.xcodeproj/xcuserdata/
# Xcode .xcworkspace private data
app/.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
# Xcode .xcworkspace index files
app/.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
# CocoaPods (if used)
app/Pods/
app/Podfile.lock
# Carthage (if used)
app/Carthage/Build/
# Xcode code coverage / profiling data
app/*.profdata
# Generated Swift module interfaces
app/*.swiftinterface

excalidraw.log