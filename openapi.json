  "components": {
    "schemas": {
      "AddHoldingRequest": {
        "properties": {
          "device_uuid": {
            "type": "string",
            "format": "uuid",
            "title": "Device Uuid"
          },
          "ticker": {
            "type": "string",
            "maxLength": 10,
            "minLength": 1,
            "title": "Ticker"
          },
          "weight": {
            "type": "number",
            "maximum": 1.0,
            "exclusiveMinimum": 0.0,
            "title": "Weight"
          }
        },
        "type": "object",
        "required": [
          "device_uuid",
          "ticker",
          "weight"
        ],
        "title": "AddHoldingRequest",
        "description": "Request body for adding a holding to a device portfolio."
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "appAttestMissing",
          "conflictDetected",
          "lossyMappingRejected",
          "portfolioNotFound",
          "schemaUnsupported",
          "stockDataMissing",
          "stockDataPending",
          "stockDataStale",
          "syncUnavailable",
          "unsupportedMovingAverageWindow"
        ],
        "title": "ErrorCode",
        "description": "Stable machine-readable error codes for clients."
      },
      "ErrorEnvelope": {
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "retry_after_seconds": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Retry After Seconds"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorEnvelope",
        "description": "Structured HTTP error body decoded by iOS clients."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "required": [
          "status"
